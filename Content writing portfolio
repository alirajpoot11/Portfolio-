<title>Muhammad Abbas — Content Writer & Copywriter</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0D1B2A;
  --navy2:#162436;
  --navy3:#1e3048;
  --paper:#F8F5EF;
  --cream:#EDE8DF;
  --gold:#D4A853;
  --gold2:#e8c27a;
  --white:#FDFCFA;
  --muted:#8A9BB0;
  --text:#1a2a3a;
}
html{scroll-behavior:smooth}
body{background:var(--paper);color:var(--text);font-family:Georgia,'Times New Roman',serif;font-weight:300;line-height:1.7;overflow-x:hidden}

nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(13,27,42,0.97);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:56px;border-bottom:1px solid rgba(212,168,83,0.15)}
.nav-logo{font-size:18px;color:var(--white);font-weight:700;text-decoration:none;font-family:Georgia,serif}
.nav-logo span{color:var(--gold)}
.nav-links{display:flex;gap:20px}
.nav-links a{color:var(--muted);font-size:13px;text-decoration:none;font-family:Arial,sans-serif}
.nav-links a:hover{color:var(--gold)}

.hero{background:var(--navy);min-height:100vh;display:flex;align-items:center;padding:90px 24px 70px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse at 70% 50%, rgba(212,168,83,0.06) 0%, transparent 60%)}
.hero-inner{max-width:800px;margin:0 auto;position:relative;z-index:2}
.hero-eyebrow{display:flex;align-items:center;gap:12px;margin-bottom:24px}
.hero-line{width:36px;height:1px;background:var(--gold)}
.hero-eyebrow span{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600;font-family:Arial,sans-serif}
h1{font-family:Georgia,'Times New Roman',serif;font-size:clamp(52px,10vw,88px);font-weight:700;line-height:0.95;color:var(--white);margin-bottom:8px;letter-spacing:-1px}
h1 em{color:var(--gold);font-style:italic}
.hero-title{font-family:Georgia,serif;font-size:clamp(20px,3vw,28px);color:rgba(248,245,239,0.5);font-weight:400;font-style:italic;margin-bottom:28px}
.hero-desc{font-size:15px;color:rgba(248,245,239,0.65);max-width:500px;line-height:1.8;margin-bottom:40px;font-family:Arial,sans-serif}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap}
.btn-primary{background:var(--gold);color:var(--navy);padding:13px 28px;font-size:12px;font-weight:700;text-decoration:none;letter-spacing:1px;text-transform:uppercase;font-family:Arial,sans-serif;display:inline-block}
.btn-primary:hover{background:var(--gold2)}
.btn-secondary{border:1px solid rgba(248,245,239,0.25);color:var(--white);padding:13px 28px;font-size:12px;font-weight:400;text-decoration:none;letter-spacing:1px;text-transform:uppercase;font-family:Arial,sans-serif;display:inline-block}
.btn-secondary:hover{border-color:var(--gold);color:var(--gold)}
.hero-stats{display:flex;gap:32px;margin-top:50px;padding-top:36px;border-top:1px solid rgba(255,255,255,0.07);flex-wrap:wrap}
.stat-num{font-family:Georgia,serif;font-size:36px;font-weight:700;color:var(--gold);line-height:1}
.stat-label{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:4px;font-family:Arial,sans-serif}

section{padding:70px 24px}
.inner{max-width:840px;margin:0 auto}
.sec-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.sec-line{width:28px;height:1px;background:var(--gold)}
.sec-eyebrow span{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600;font-family:Arial,sans-serif}
h2{font-family:Georgia,'Times New Roman',serif;font-size:clamp(30px,5vw,46px);font-weight:700;line-height:1.1;margin-bottom:36px;letter-spacing:-0.5px}

#about{background:var(--white)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
.about-text p{font-size:15px;color:#3d4f5f;line-height:1.9;margin-bottom:14px;font-family:Arial,sans-serif}
.sidebar-card{background:var(--navy);padding:24px;margin-bottom:14px}
