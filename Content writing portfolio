.sidebar-item{display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.06);font-size:13px;color:rgba(248,245,239,0.75);font-family:Arial,sans-serif}
.sidebar-item:last-child{border:none}
.sidebar-dot{width:5px;height:5px;background:var(--gold);flex-shrink:0}
.tools-row{display:flex;flex-wrap:wrap;gap:7px}
.tool-tag{background:rgba(212,168,83,0.1);border:1px solid rgba(212,168,83,0.2);color:var(--gold2);font-size:11px;padding:4px 10px;font-family:Arial,sans-serif}

#services{background:var(--cream)}
.services-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;background:rgba(13,27,42,0.1)}
.svc{background:var(--white);padding:32px 28px;transition:background 0.25s}
.svc:hover{background:var(--navy)}
.svc:hover .svc-title{color:var(--white)}
.svc:hover .svc-desc{color:rgba(248,245,239,0.65)}
.svc:hover .svc-num{color:rgba(212,168,83,0.15)}
.svc-num{font-family:Georgia,serif;font-size:48px;font-weight:700;color:rgba(13,27,42,0.07);line-height:1;margin-bottom:10px;transition:color 0.25s}
.svc-title{font-family:Georgia,serif;font-size:20px;font-weight:700;margin-bottom:8px;color:var(--navy);transition:color 0.25s}
.svc-desc{font-size:13px;color:#5a6a7a;line-height:1.7;transition:color 0.25s;font-family:Arial,sans-serif}

#portfolio{background:var(--navy);padding-bottom:70px}
#portfolio h2{color:var(--white)}
.port-tabs{display:flex;gap:2px;margin-bottom:2px;background:rgba(255,255,255,0.05)}
.tab-btn{padding:11px 22px;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;background:transparent;border:none;color:var(--muted);cursor:pointer;transition:all 0.2s;font-family:Arial,sans-serif}
.tab-btn.active{background:var(--gold);color:var(--navy)}
.tab-btn:hover:not(.active){color:var(--white)}
.tab-content{display:none}
.tab-content.active{display:block}
.port-item{background:var(--navy2);border-bottom:1px solid rgba(255,255,255,0.05)}
.port-header{padding:24px 28px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:background 0.2s}
.port-header:hover{background:var(--navy3)}
.port-meta{display:flex;align-items:center;gap:12px;margin-bottom:7px}
.port-type{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);font-weight:600;border:1px solid rgba(212,168,83,0.3);padding:3px 9px;font-family:Arial,sans-serif}
.port-niche{font-size:11px;color:var(--muted);font-family:Arial,sans-serif}
.port-title{font-family:Georgia,serif;font-size:20px;color:var(--white);font-weight:700;line-height:1.3}
.port-excerpt{font-size:13px;color:rgba(248,245,239,0.4);margin-top:5px;font-family:Arial,sans-serif}
.port-arrow{font-size:14px;color:var(--gold);transition:transform 0.3s;flex-shrink:0;margin-left:16px}
.port-arrow.open{transform:rotate(180deg)}
.port-body{max-height:0;overflow:hidden;transition:max-height 0.5s ease}
.port-body.open{max-height:3000px}
.port-content{padding:0 28px 32px}
.port-content h3{font-family:Georgia,serif;font-size:22px;color:var(--white);margin-bottom:5px;font-weight:700}
.port-content .pmeta{font-size:11px;color:var(--muted);margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,0.07);font-family:Arial,sans-serif}
.port-content p{font-size:14px;color:rgba(248,245,239,0.72);line-height:1.85;margin-bottom:12px;font-family:Arial,sans-serif}
.port-content h4{font-family:Georgia,serif;font-size:17px;color:var(--gold2);margin:18px 0 7px;font-weight:700}
.port-content ul{margin:0 0 12px 18px}
.port-content ul li{font-size:14px;color:rgba(248,245,239,0.72);line-height:1.8;margin-bottom:3px;font-family:Arial,sans-serif}
.port-content strong{color:var(--white);font-weight:600}

.pd-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:rgba(255,255,255,0.05)}
.pd-card{background:var(--navy2);padding:24px 20px}
.pd-platform{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:9px;font-family:Arial,sans-serif}
.pd-card h3{font-family:Georgia,serif;font-size:16px;color:var(--white);font-weight:700;margin-bottom:12px;line-height:1.3}
.pd-card p{font-size:13px;color:rgba(248,245,239,0.65);line-height:1.75;margin-bottom:8px;font-family:Arial,sans-serif}
.pd-card ul{margin:8px 0 8px 15px}
.pd-card ul li{font-size:12px;color:rgba(248,245,239,0.65);line-height:1.7;margin-bottom:3px;font-family:Arial,sans-serif}
.pd-cta-btn{display:inline-block;margin-top:12px;background:var(--gold);color:var(--navy);font-size:10px;font-weight:700;padding:7px 16px;letter-spacing:1px;text-transform:uppercase;font-family:Arial,sans-serif}

#contact{background:var(--navy);text-align:center}
#contact h2{color:var(--white)}
.contact-sub{font-size:14px;color:var(--muted);margin-bottom:36px;max-width:460px;margin-left:auto;margin-right:auto;line-height:1.8;font-family:Arial,sans-serif}
.contact-cards{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;margin-bottom:36px}
.contact-card{background:var(--navy2);border:1px solid rgba(212,168,83,0.15);padding:18px 22px;min-width:155px;transition:border-color 0.2s;text-decoration:none;display:block}
.contact-card:hover{border-color:var(--gold)}
.cc-icon{font-size:20px;margin-bottom:7px}
.cc-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:4px;font-family:Arial,sans-serif}
.cc-val{font-size:12px;color:var(--white);font-family:Arial,sans-serif;word-break:break-all}
.contact-btns{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}

footer{background:#080f18;padding:20px 24px;text-align:center}
footer p{font-size:12px;color:rgba(138,155,176,0.45);font-family:Arial,sans-serif}
footer span{color:var(--gold)}

.reveal{opacity:0;transform:translateY(24px);transition:opacity 0.6s ease,transform 0.6s ease}
.reveal.visible{opacity:1;transform:none}

@media(max-width:700px){
  .about-grid{grid-template-columns:1fr}
  .services-grid{grid-template-columns:1fr}
  .pd-grid{grid-template-columns:1fr}
  .nav-links{display:none}
  .hero-stats{gap:20px}
}
</style>
</head>
